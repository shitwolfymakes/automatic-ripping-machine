POSTGRES_USER=arm
POSTGRES_PASSWORD=change-me-openssl-rand-hex-24
POSTGRES_DB=arm

ARM_SERVICE_TOKEN=change-me-openssl-rand-hex-32

PUID=1000
PGID=1000
CDROM_GID=44

ARM_LOG_LEVEL=info

# Optional OMDB API key. When set, overrides config.omdb_api_key on every
# identify call (handy in dev — keep the secret out of the DB).
OMDB_API_KEY=

# Comma-separated allowlist of `Origin` header values the WebSocket endpoint
# accepts from browser clients. Service-token connections (rippers /
# transcoders) skip this check via subprotocol marker. Add every URL the UI
# is reachable at — bare `localhost:8081` for the dev host, plus your LAN
# hostname / IP if you log in from another device.
ARM_ALLOWED_ORIGINS=https://localhost:8081

# Phase 7: transcode dispatcher.
#
# MAX_PARALLEL_TRANSCODES — how many transcoder containers may run at once.
# A 1080p HandBrake transcode pegs every CPU core; default 1 is conservative.
MAX_PARALLEL_TRANSCODES=1

# The image name the dispatcher passes to docker. Built locally via
# `docker compose build arm-transcode-builder`; production installs pull a
# tagged image.
ARM_TRANSCODE_IMAGE=arm-transcode:dev

# Backend's host-side mount paths. Required because the Backend spawns
# transcoder containers via the docker socket — the daemon resolves these
# host paths, not the Backend container's `/raw` etc. Compose substitutes
# `${PWD}` at parse time so these stay portable across checkouts.
ARM_HOST_RAW_PATH=${PWD}/raw
ARM_HOST_MEDIA_PATH=${PWD}/media
ARM_HOST_LOGS_PATH=${PWD}/logs
ARM_HOST_CERTS_PATH=${PWD}/certs

# Docker network the spawned transcoder joins so it can reach
# `https://arm-backend:8443`. Compose default is `<project>_default`;
# our project is named `armv3`.
ARM_DOCKER_NETWORK=armv3_default
