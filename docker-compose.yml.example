name: armv3

services:
  arm-db:
    image: postgres:18
    container_name: armv3-db
    restart: unless-stopped
    entrypoint:
      - bash
      - -c
      - |
        install -o postgres -g postgres -m 0600 /etc/ssl/arm/tls.key /tmp/pg.key
        install -o postgres -g postgres -m 0644 /etc/ssl/arm/tls.crt /tmp/pg.crt
        exec docker-entrypoint.sh postgres \
          -c ssl=on \
          -c ssl_cert_file=/tmp/pg.crt \
          -c ssl_key_file=/tmp/pg.key \
          -c ssl_ca_file=/etc/ssl/arm/arm-ca.crt
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    volumes:
      - ./arm/db:/var/lib/postgresql
      - ./arm/certs/arm-ca.crt:/etc/ssl/arm/arm-ca.crt:ro
      - ./arm/certs/arm-db.crt:/etc/ssl/arm/tls.crt:ro
      - ./arm/certs/arm-db.key:/etc/ssl/arm/tls.key:ro

  arm-backend:
    build:
      context: .
      dockerfile: services/backend/Dockerfile
    container_name: armv3-backend
    restart: unless-stopped
    depends_on:
      - arm-db
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@arm-db:5432/${POSTGRES_DB}?sslmode=verify-full&sslrootcert=/etc/ssl/arm/arm-ca.crt
      ARM_SERVICE_TOKEN: ${ARM_SERVICE_TOKEN}
      ARM_LOG_LEVEL: ${ARM_LOG_LEVEL:-info}
      OMDB_API_KEY: ${OMDB_API_KEY:-}
      ARM_ALLOWED_ORIGINS: ${ARM_ALLOWED_ORIGINS:-}
      TLS_CERT_PATH: /etc/ssl/arm/tls.crt
      TLS_KEY_PATH: /etc/ssl/arm/tls.key
      PUID: ${PUID:-1000}
      PGID: ${PGID:-1000}
      # Phase 7 — transcode dispatcher needs host paths (the docker daemon
      # interprets these, NOT the Backend container's filesystem).
      MEDIA_ROOT: /media
      MAX_PARALLEL_TRANSCODES: ${MAX_PARALLEL_TRANSCODES:-1}
      ARM_TRANSCODE_IMAGE: ${ARM_TRANSCODE_IMAGE:-arm-transcode:latest}
      # Default to the same host paths the bind mounts below resolve to —
      # `${PWD}` is the directory `docker compose` was invoked from, which
      # for this project is always the repo root. Override in `.env` only if
      # you've moved the data out of the repo tree.
      ARM_HOST_RAW_PATH: ${ARM_HOST_RAW_PATH:-${PWD}/arm/raw}
      ARM_HOST_MEDIA_PATH: ${ARM_HOST_MEDIA_PATH:-${PWD}/arm/media}
      ARM_HOST_LOGS_PATH: ${ARM_HOST_LOGS_PATH:-${PWD}/arm/logs}
      ARM_HOST_CERTS_PATH: ${ARM_HOST_CERTS_PATH:-${PWD}/arm/certs}
      ARM_DOCKER_NETWORK: ${ARM_DOCKER_NETWORK:-armv3_default}
      # Phase 7b — GPUs detected host-side by setup-dev.sh into ARM_GPUS. The
      # GPU-free backend reads this to fill the gpus table; the dispatcher
      # injects device access into each ephemeral transcoder. [] => CPU-only.
      ARM_GPUS: ${ARM_GPUS:-[]}
      ARM_RENDER_GID: ${ARM_RENDER_GID:-}
    volumes:
      - ./arm/logs:/logs
      - ./arm/media:/media
      - ./arm/raw:/raw
      - ./arm/certs/arm-ca.crt:/etc/ssl/arm/arm-ca.crt:ro
      - ./arm/certs/arm-backend.crt:/etc/ssl/arm/tls.crt:ro
      - ./arm/certs/arm-backend.key:/etc/ssl/arm/tls.key:ro
      # Phase 7 — Backend spawns arm-transcode-* containers via the socket.
      # Acceptable per docs/arch/06-deployment.md (root-equivalent on host).
      - /var/run/docker.sock:/var/run/docker.sock
    # Uncomment to reach Backend directly from the host for verification curl:
    # ports:
    #   - "8443:8443"

  # The fat HW transcode image. `deploy.replicas: 0` means `docker compose up`
  # BUILDS it (so a plain `up -d --build` tags arm-transcode:latest) but starts
  # zero containers — the Backend dispatcher spawns short-lived transcoder
  # containers from this image per task via the docker socket. Don't give it a
  # profile: profiles would also exclude it from `up`/`build`, so the image
  # would never get built locally.
  arm-transcode:
    image: ${ARM_TRANSCODE_IMAGE:-arm-transcode:latest}
    build:
      context: .
      dockerfile: services/transcode/Dockerfile
    deploy:
      replicas: 0

  arm-ui:
    build:
      context: .
      dockerfile: services/ui/Dockerfile
    container_name: armv3-ui
    restart: unless-stopped
    depends_on:
      - arm-backend
    ports:
      - "8081:443"
    volumes:
      - ./arm/certs/arm-ca.crt:/etc/ssl/arm/arm-ca.crt:ro
      - ./arm/certs/arm-ui.crt:/etc/ssl/arm/tls.crt:ro
      - ./arm/certs/arm-ui.key:/etc/ssl/arm/tls.key:ro

  # >>> arm-ripper services (generated by devtools/setup-dev.sh) — do not edit by hand
  # `bash devtools/setup-dev.sh` copies this template to docker-compose.yml
  # (gitignored, like .env) and fills this region with one arm-ripper-srN
  # service per optical drive, pairing each /dev/srN with its /dev/sgM node via
  # `lsscsi -g`. Left empty in the committed template — the real file is
  # host-specific. Re-run setup-dev.sh after attaching or removing a drive.
  # <<< arm-ripper services
