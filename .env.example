POSTGRES_USER=arm
POSTGRES_PASSWORD=change-me-openssl-rand-hex-24
POSTGRES_DB=arm

ARM_SERVICE_TOKEN=change-me-openssl-rand-hex-32

PUID=1000
PGID=1000
CDROM_GID=44

ARM_LOG_LEVEL=info

# Optional OMDB API key. When set, overrides config.omdb_api_key on every
# identify call (handy in dev — keep the secret out of the DB).
OMDB_API_KEY=

# Comma-separated allowlist of `Origin` header values the WebSocket endpoint
# accepts from browser clients. Service-token connections (rippers /
# transcoders) skip this check via subprotocol marker. Add every URL the UI
# is reachable at — bare `localhost:8081` for the dev host, plus your LAN
# hostname / IP if you log in from another device.
ARM_ALLOWED_ORIGINS=https://localhost:8081

# Phase 7: transcode dispatcher.
#
# MAX_PARALLEL_TRANSCODES — how many transcoder containers may run at once.
# A 1080p HandBrake transcode pegs every CPU core; default 1 is conservative.
MAX_PARALLEL_TRANSCODES=1

# The image the dispatcher spawns per task. In dev it is BUILT LOCALLY and tagged
# `arm-transcode:latest` by `devtools/setup-dev.sh` (via `docker compose
# --profile build-transcode build arm-transcode-builder`) — nothing is pulled.
# Production installs pull the versioned tag instead (install.sh derives it from
# ARM_IMAGE_PREFIX/ARM_IMAGE_TAG). It's the fat multi-vendor HW image — VAAPI/QSV
# userspace baked in, NVENC injected at runtime by the host's nvidia-container-toolkit.
ARM_TRANSCODE_IMAGE=arm-transcode:latest

# Backend's host-side mount paths. Required because the Backend spawns
# transcoder containers via the docker socket — the daemon resolves these
# host paths, not the Backend container's `/raw` etc. Compose substitutes
# `${PWD}` at parse time so these stay portable across checkouts.
ARM_HOST_RAW_PATH=${PWD}/raw
ARM_HOST_MEDIA_PATH=${PWD}/media
ARM_HOST_LOGS_PATH=${PWD}/logs
ARM_HOST_CERTS_PATH=${PWD}/certs

# Docker network the spawned transcoder joins so it can reach
# `https://arm-backend:8443`. Compose default is `<project>_default`;
# our project is named `armv3`.
ARM_DOCKER_NETWORK=armv3_default

# Phase 7b: GPU transcoding.
#
# GPUs are detected host-side at install time — `devtools/setup-dev.sh` (dev) and
# `install.sh` (prod) enumerate /dev/dri render nodes (Intel QSV / AMD VAAPI) and
# `nvidia-smi` (NVIDIA NVENC) and write the result here as a JSON array. The
# GPU-free backend reads ARM_GPUS to fill the `gpus` table; the dispatcher injects
# the matching device access into each ephemeral transcoder. No overlay, no
# COMPOSE_FILE juggling. Re-run the installer after a GPU/driver change.
#
# Empty array => CPU-only transcoding (zero behavior change). Example populated:
#   ARM_GPUS=[{"vendor":"qsv","device_path":"/dev/dri/renderD128","encoder_kinds":["h264","h265"]}]
ARM_GPUS=[]
#
# NVIDIA hosts also need nvidia-container-toolkit so the docker daemon can pass
# GPU device files into the transcoder. install.sh offers to set this up on apt
# hosts; otherwise install it manually and run `sudo nvidia-ctk runtime configure
# --runtime=docker && sudo systemctl restart docker`.
#
# Built-in transcode presets default to `hw_preference=NULL` ("prefer GPU,
# queue if all busy, CPU only if no GPU advertises this codec").
